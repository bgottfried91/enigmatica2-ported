    {
      id: "02000000002F0000",
      title: "Incense Altar I",
      x: 5.67,
      y: 7,
      tasks: [
        {
          id: "03000000002F0000",
          type: "item",
          item: "bloodmagic:incensealtar"
        }
      ],
      description: ["The incense altar is an item that can be incorporated into a multiblock structure in order to aid your self-sacrifice. You can check the current benefit with a sigil of divination. It should start at 20% and may add up to 300%!", "", "Later tiers will feature a value of \"tranquility\", which can also be seen with the sigil. Tranquility is gained by having different kind of blocks in the radius of the altar.", "", "In order to expand the alter into a multiblock, you need to place 3 blocks wide paths going from the 3 x 3 it is placed on, rising in tier as the distance to the altar increases.", "", "See the Sanguine Scientiem for details."],
      icon: "bloodmagic:incensealtar",
      dependencies: ["0200000003C90000"],
      rewards: [
        {
          id: "04000000002F0000",
          type: "item",
          item: "minecraft:oak_log",
          count: 12
