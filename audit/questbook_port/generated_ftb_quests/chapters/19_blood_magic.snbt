      title: "Demon Crystalizer",
      x: 7.17,
      y: 8.5,
      tasks: [
        {
          id: "0300000000370000",
          type: "item",
          item: "bloodmagic:demoncrystallizer"
        }
      ],
      description: ["The Demon Crystalizer can drain the demonic will in the chunk in order to confine it to small nodes of crystals. These nodes take a lot of will to initially grow, but require much less to grow additional crystals, giving you a small net gain should you melt them in the Demon Crucible.", "", "They may be broken with a sufficiently powerful pickaxe, but a powerful magus with more than 1024 will in his inventory may find that right-clicking the node allows him to take off crystals without breaking the main node."],
      icon: "bloodmagic:demoncrystallizer",
      dependencies: ["0200000000360000"],
