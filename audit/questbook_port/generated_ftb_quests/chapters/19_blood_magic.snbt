  quests: [
    {
      id: "0200000000250000",
      title: "Tome of Peritia",
      x: 9.83,
      y: 0.67,
      tasks: [
        {
          id: "0300000000250000",
          type: "item",
          item: "bloodmagic:experiencebook"
        }
      ],
      description: ["This tome allows you to rapidly store your levels in it for later use, or withdraw levels to use in enchanting. This allows you to not waste high levels on lower-level enchantments, and safeguards you in case of death.", "", "It will automatically absorb experience you gather while it is in your inventory."],
      icon: "bloodmagic:experiencebook",
      rewards: [
        {
          id: "0400000000250000",
          type: "xp",
          xp: 10
        }
