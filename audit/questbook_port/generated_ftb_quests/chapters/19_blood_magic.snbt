    {
      id: "0200000000260000",
      title: "Living Armor",
      x: 2,
      y: 6.33,
      tasks: [
        {
          id: "0300000000260000",
          type: "item",
          item: "bloodmagic:reagentbinding",
          count: 4
        }
      ],
      description: ["Living armor is powerful protection that will evolve to fit your needs. It will remember key events such as taking damage or sprinting/jumping a lot and spend its upgrade points automatically to aid you with helpful traits.", "", "There are several rituals available to cleanse your armor of unwanted buffs or inflict it with curses in order to increase its capabilities further. See the Sanguine Scientiem for details!", "", "This armor can permanently break, but it can be repaired with binding agent in an anvil (or learn to slowly repair itself).", "", "A full set of armor is required for it to work."],
      icon: "bloodmagic:livingplate",
      dependencies: ["0200000003D10000"],
