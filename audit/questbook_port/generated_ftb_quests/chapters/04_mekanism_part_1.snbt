      tasks: [
        {
          id: "0300000000610000",
          type: "checkmark",
          title: "checkbox"
        }
      ],
      description: ["Mekanism likes to use shortcuts when it comes to power display, rather than raw numbers, and they're not all obvious. So here they are:", "KRF = Thousand RF (1.000)", "MRF = Million RF      (1.000.000)", "GRF = Billion RF       (1.000.000.000)", "TRF = Trillion RF      (1.000.000.000.000)", "PRF = Quadtrillion RF (1.000.000.000.000.000)", "ERF = Quintillion RF    (1.000.000.000.000.000.000)", "ZRF = Sextillion RF     (1.000.000.000.000.000.000.000)", "So for a few examples: 1.6 KRF = 1.600 RF. 16.27 GRF = 16.270.000.000 RF, or as most mods likes to display it: 16.270M RF"],
      icon: "mekanism:upgrade_energy",
      dependencies: ["02000000005E0000"],
      rewards: [
