        },
        {
          id: "0400000000800001",
          type: "item",
          item: "mekanism:ultimate_control_circuit",
          count: 6,
          title: "Choice option: mekanism:ultimate_control_circuit"
        }
      ]
    },
    {
      id: "0200000000810000",
      title: "That's a lot of ingots..",
      x: 7,
      y: 2,
      tasks: [
        {
          id: "0300000000810000",
