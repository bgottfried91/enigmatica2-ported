    {
      id: "02000000009F0000",
      title: "More Steam than you could ever need",
      x: 11,
      y: 11.5,
      tasks: [
        {
          id: "03000000009F0000",
          type: "item",
          item: "mekanismgenerators:fusion_reactor_port",
          count: 5
        }
      ],
      description: ["The Fusion Reactor can also be used to produce Steam.", "The only thing required is an additional 2 Reactor Ports, and to set the Injection Rate to 4 or more.", "One of the Ports is for Water Input, and the other is for Steam Output.", "Simply pumping Water into the Reactor will make it start producing Steam at upto 150.000mb/t.", "The Water:Steam ratio is 1:1.", "It is important to use the Configurator on the Steam Reactor Port to set it to Output. It will still produce half the RF while producing Steam.", "", "NOTE: You may want to put the Reactor Port (Output) directly next to the Steam Input of your Turbine (so no pipes between), unless you have a pipe with unlimited Pump Rate."],
      icon: "mekanismgenerators:turbine_blade",
      dependencies: ["02000000008A0000"],
      rewards: [
        {
          id: "04000000009F0000",
          type: "item",
          item: "mekanism:alloy_atomic",
          count: 8,
          title: "Choice option: mekanism:alloy_atomic"
        },
        {
          id: "04000000009F0001",
          type: "item",
          item: "mekanism:ultimate_control_circuit",
          count: 6,
          title: "Choice option: mekanism:ultimate_control_circuit"
        }
      ]
    },
    {
      id: "0200000000A00000",
      title: "Maximum Security!",
      x: 14,
      y: 0,
      tasks: [
        {
          id: "0300000000A00000",
          type: "item",
          item: "mekanism:security_desk"
        }
      ],
      description: ["[Multiplayer Only]", "This block is used to control the security of your machines. Every machine with an Interface has Security settings. Public, Private and Trusted.", "On Public, anyone can access it.", "On Private, only you can access it.", "On Trusted, only persons that you put on the Trusted List can access it. The Trusted List is in the Security Desk, and is the only place to add/remove people from the list.", "The Security Desk has 3 security settings at the bottom, and machines put in the bottom right slot, will have that setting applied to them.", "To unlock a machine you own, put it in the top right slot.", "The \"Security Overwrite\" will set all the machines you own, to the selected Security setting in the Security Desk. Very handy if you have some people sneaking around with your machines!"],
      icon: "mekanism:security_desk",
      dependencies: ["02000000007F0000"],
      rewards: [
        {
          id: "0400000000A00000",
          type: "random",
          table_id: 360287970189705216
        }
      ]
    },
    {
      id: "0200000000A10000",
      title: "Putting Steam to use",
      x: 4,
      y: 0,
      tasks: [
        {
          id: "0300000000A10000",
          type: "item",
          item: "mekanismgenerators:turbine_casing",
          count: 64
        },
        {
          id: "0300000000A10001",
          type: "item",
          item: "mekanismgenerators:turbine_valve",
          count: 2
        },
        {
          id: "0300000000A10002",
          type: "item",
