    {
      id: "02000000009B0000",
      title: "Pet on a leash - without the leash",
      x: 2,
      y: 8,
      tasks: [
        {
          id: "03000000009B0000",
          type: "item",
          item: "mekanism:robit"
        }
      ],
      description: ["The Robit is a companion that can follow you around. You have to place it down on a Charge Pad, which will act as its home.", "The Robit can providing all kinds of services.", "It can pick up blocks you drop, and put it in its inventory, which also can act as a chest.", "It can provide Crafting Table, Furnance (requires fuel) and Anvil features as well.", "The robit loses energy when it takes damage. Should it run out of energy, either from damage or usage, it will automatically teleport back home.", "You can of course also tell it yourself to teleport back home. And of course you can rename it too.", "To pick it up again, Shift-Right Click it with a Configurator. After being picked up, you can set a new home to it on a different Charged Pad if you desire."],
      icon: "mekanism:robit",
      dependencies: ["02000000007C0000"],
      rewards: [
