    {
      id: "0200000001970000",
      title: "Teleports all over!",
      x: 8,
      y: 10,
      tasks: [
        {
          id: "0300000001970000",
          type: "item",
          item: "draconicevolution:advanced_dislocator"
        }
      ],
      description: ["The Advanced Dislocator is a portable device, that can save multiple locations to teleport to.", "Shift-Right Click to open the GUI, where you can add, change, name and delete Locations.", "Right Click a location in the GUI to teleport to it.", "You can have 1 Quick Location on the Advanced Dislocator. Shift-Scroll with the Advanced Dislocator to change the Quick Location.", "Right Click to teleport to the Quick Location.", "Click on an entity (both passive and hostile) to teleport it to your Quick Location.", "You can click on a sneaking player to teleport them to your Quick Location.", "", "Every teleport consumes 1 Ender Pearl"],
