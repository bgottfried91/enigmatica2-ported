  quests: [
    {
      id: "0200000000DF0000",
      title: "Link!",
      x: 0,
      y: 13,
      tasks: [
        {
          id: "0300000000DF0000",
          type: "item",
          item: "draconicevolution:crystal_binder"
        }
      ],
      description: ["The Crystal Binder is used to connect the Crystals to each other.", "Shift-Right Click a crystal with the Crystal Binder to select it, and Right Click on another crystal to link it.", "", "The Crystals will always equalize all their energy between them"],
      icon: "draconicevolution:crystal_binder",
      dependencies: ["0200000001B10000"],
      rewards: [
        {
          id: "0400000000DF0000",
          type: "random",
          table_id: 360287970189705216
        }
      ]
    },
    {
      id: "02000000015E0000",
      title: "RF Gates!",
      x: 22,
      y: 8,
      tasks: [
        {
          id: "03000000015E0000",
          type: "item",
          item: "draconicevolution:flux_gate",
          count: 2
        }
      ],
      description: ["These Flux Gates can limit how much RF flows through them, based on Redstone signal (on or off).", "They are very useful when it comes to controlling the flow of your Draconic Reactor.", "You will need 2 of them, one for the energy input, and one for the energy output."],
      icon: "draconicevolution:flux_gate",
      dependencies: ["0200000001A80000"],
      rewards: [
        {
          id: "04000000015E0000",
          type: "random",
          table_id: 360287970189705216
        }
      ]
    },
    {
      id: "0200000001760000",
      title: "The most advanced stabilizers!",
      x: 22,
      y: 6,
      tasks: [
        {
          id: "0300000001760000",
          type: "item",
          item: "draconicevolution:reactor_stabilizer",
          count: 4
        }
      ],
      description: ["The Reactor Stabilizers are what keeps the Draconic Reactor from exploding.", "The Draconic Reactor needs 4 Reactor Stabilizers, that all has to be placed in either a horizontal or vertical plane. Just like the Energy Core.", "You also use these to take energy out of the Draconic Reactor, which is your net gain.", "This is where the Flux Gates comes in handy.", "Each Reactor Stabilizer can give a Comparator output, depending on the Redstone Mode it's set too.", "", "Recommended that each Reactor Stabilizer is at least 4 blocks from the Reactor Core."],
      icon: "draconicevolution:reactor_stabilizer",
      dependencies: ["0200000001A80000"],
      rewards: [
        {
          id: "0400000001760000",
          type: "random",
          table_id: 360287970189705216
        }
      ]
    },
    {
      id: "02000000017C0000",
      title: "Pumpin Power!",
      x: 22,
      y: 10,
      tasks: [
        {
          id: "03000000017C0000",
          type: "item",
          item: "draconicevolution:reactor_injector"
        }
      ],
      description: ["The Reactor Energy Injector is what gives power to the Containment Field shield, and is therefor also the input for the Draconic Reactor.", "This has to be placed on one of the 2 sides, where there's not a Reactor Stabilizer.", "A Flux Gate is recommended to be used with this.", "The Reactor Energy Injector can give out a Comparator output, depending on the Redstone Mode it's set to.", "", "Recommended to be at least 4 blocks away from the Reactor Core."],
      icon: "draconicevolution:reactor_injector",
      dependencies: ["0200000001A80000"],
      rewards: [
        {
          id: "04000000017C0000",
          type: "random",
          table_id: 360287970189705216
        }
      ]
    },
    {
      id: "02000000017F0000",
      title: "UNLIMITED POWAH",
      x: 12.75,
      y: 11.25,
      tasks: [
        {
          id: "03000000017F0000",
          type: "item",
          item: "draconicevolution:draconic_staff"
        }
      ],
      description: ["The ultimate All-In-One tool.. well except ranged weapon.", "It gains all the benefits of Sword, Pickaxe, Axe and Shovel.", "Attack and Dig AOE radius can be changed individually in the Draconic GUI.", "", "When fully upgraded and enchanted, it is a beast to behold.", "", "The Staff of Power comes with +3 Reaper enchant."],
      icon: "draconicevolution:draconic_staff",
      dependencies: ["02000000018E0000", "0200000001AB0000", "0200000001AE0000"],
      rewards: [
        {
          id: "04000000017F0000",
          type: "random",
          table_id: 360287970189705216
        }
      ]
    },
    {
      id: "0200000001850000",
      title: "I see you...",
      x: 0,
      y: 7,
      tasks: [
        {
          id: "0300000001850000",
          type: "item",
          item: "draconicevolution:entity_detector"
        }
      ],
      description: ["A small entity detector, that can.... detect nearby enemies.", "It has serveral settings, and takes power everytime it scans for new entities.", "The power cost is per Pulse, and the cost of a Pulse depends on the range of the detector.", "It can pulse between every 1.5s and 60s.", "It has settings for how many entities needs to be within range to give a certain redstone signal.", "And it has some basic entity filters.", "Redstone Output can be either Fixed or Pulse", "", "For some extra information, check the Draconic Tablet.", "This Entity Detector does not detect Item Entities."],
      icon: "draconicevolution:entity_detector",
      dependencies: ["02000000019B0000"],
      rewards: [
        {
          id: "0400000001850000",
          type: "random",
          table_id: 360287970189705216
        }
      ]
    },
    {
      id: "0200000001860000",
      title: "Relocated Spawners",
      x: 0,
      y: 5,
      tasks: [
        {
          id: "0300000001860000",
          type: "item",
          item: "draconicevolution:stabilized_spawner"
        }
      ],
      description: ["In Draconic Evolution it is possible to control, and change spawners.", "First you need to find a mob spawner though, but you must &cnot&r break it (like you do in EnderIO).", "Then right click it with any Draconic Core, and it will drop as an item. This will consume the core.", "", "Your new Spawner doesn't use any power, and can be turned off with a redstone signal.", "The efficiency of the spawner depends on the core thats on top of it. It is possible to replace the core, just right click with another core, and you will get the old one back. More information in the Draconic Tablet on what each tier of Core allows.", "You can also change the type of mob that the spawner spawns, but getting a Mob Soul.", "Mob Souls have a very low chance to drop when killed by a sword with the Reaper enchant. More on that in the Enchants quest.", "", "&cBreaking a Stabilized Mob Spawner will cause it to lose its current soul."],
      icon: "draconicevolution:stabilized_spawner",
      dependencies: ["02000000019B0000"],
      rewards: [
        {
          id: "0400000001860000",
          type: "random",
          table_id: 360287970189705216
        }
      ]
    },
    {
      id: "0200000001870000",
      title: "Enchants and Item Settings",
      x: 10,
      y: 3,
      tasks: [
        {
          id: "0300000001870000",
          type: "item",
          item: "draconicevolution:disenchanter"
        }
      ],
      description: ["All the armor, tools and weapons from Draconic Evolution are enchantable.", "The only way to enchant them, is in an Anvil with an Enchanted Book.", "A good way to get Enchants is Fishing, Dungeons and Disenchanting gear with the Disenchanter. This costs Levels to use.", "", "Draconic Evolution also adds a new enchant: Reaper. This goes up to V, and does not interfere with anything else.", "Reaper increases the chance to get Mob Souls when killing mobs. The chance of getting a Mob Soul is 1000/ReaperEnchLvl. So a Diamond Sword with Reaper V, will have 1 in 200 chance on mob kill to drop a Mob Soul.", "Wyvern Sword comes with +1 to Reaper (Max of Reaper VI, 1 in 166 chance)", "Draocnic Sword comes with +2 to Reaper (Max of Reaper VII, 1 in 142 chance)", "Staff of Power comes with +3 to Reaper (Max of Reaper VIII, 1 in 125 chance)", "", "&m-------------------------------------------------------------------------", "&m&k&l&m&m&n&o&rItem Settings:", "Most of Draconic Evolution items has settings of some sorts. To change those settings, you need to go into the Draconic GUI (default \"C\")", "&cNOTE: This conflicts with the default Psi keybind, which takes priority, so you may have to change either keybind to something else.", "&rOnce you're in the GUI, you can click each Draconic item to change their settings, and change the Profile name, and you can re-position and resize the HUD too.", "", "Profiles:", "Each item also holds up to 5 Profile settings, which can change between (default \"BACKSLASH\")"],
      icon: "minecraft:enchanted_book",
      dependencies: ["0200000001980000", "0200000001990000"],
      rewards: [
        {
          id: "0400000001870000",
          type: "random",
          table_id: 360287970189705216
        }
      ]
    },
