      x: 9,
      y: 2,
      tasks: [
        {
          id: "03000000018C0000",
          type: "item",
          item: "draconicevolution:energy_pylon",
          count: 2
        }
      ],
      description: ["To give and take from the Energy Core, you need Energy Pylons. One for Input, and one for Output.", "Place them within 16 blocks range, and put a Glass Block either above or below the Energy Pylon, which will form the energy transfer ball.", "Right-Click the energy transfer ball, to change it between Input and Output. The balls animation indicates which state it's in."],
      icon: "draconicevolution:energy_pylon",
      dependencies: ["02000000018A0000"],
      rewards: [
        {
          id: "04000000018C0000",
