    {
      id: "02000000018A0000",
      title: "Energy Ball!",
      x: 8,
      y: 4,
      tasks: [
        {
          id: "03000000018A0000",
          type: "item",
          item: "draconicevolution:energy_core"
        },
        {
          id: "03000000018A0001",
          type: "item",
          item: "draconicevolution:particle_generator",
          count: 4
        }
      ],
      description: ["You start to get some more energy, and need a place to store it.", "The Energy Core can hold quite a bit, depending on the tier.", "", "To assemble the Energy Core, the need the Energy Core in the center, with 4 Energy Core Stabilizers, formed in a \"+\" around the core - these can turn any direction, and don't have to be at the same range.", "Right click the Core, or a Stabilizer to open the GUI and activate the core.", "To get to the next tier, deactivate the core (it will save the power, aslong as you don't break the Core), click the Tier Up, turn on the Building Guide and build as the guide is showning. Then Right-Click a Stabilizer and Activate the core.", "", "To see the amount of energy, and blocks required for each Tier, check the Draconic Tablet."],
      icon: "draconicevolution:energy_core",
      dependencies: ["02000000019D0000"],
      rewards: [
        {
          id: "04000000018A0000",
          type: "random",
          table_id: 360287970189705216
        }
      ]
    },
    {
      id: "02000000018B0000",
      title: "Stabilizing in an advanced way",
      x: 7,
      y: 2,
      tasks: [
        {
          id: "03000000018B0000",
          type: "item",
          item: "draconicevolution:particle_generator",
          count: 36
        }
      ],
      description: ["You have your small Energy Core, but you wish to go bigger.", "But if you want to go bigger, you need bigger Energy Core Stabilizers. You need Advanced Energy Core Stabilizers!", "To get Advanced Energy Core Stabilizers, simply put 9 Energy Core Stabilizers in a 3x3 shape in the world. The center Stabilizier will determine the center of the Advanced Stabilizer.", "", "&cNOTE: The Retrieval Task will also include the base 4 Energy Core Stabilizers for the T1-T4 Energy Core"],
      icon: "draconicevolution:particle_generator",
      dependencies: ["02000000018C0000"],
      rewards: [
        {
          id: "04000000018B0000",
          type: "random",
          table_id: 360287970189705216
        }
      ]
    },
    {
