        }
      ]
    }
  ],
  quest_links: [],
  subtitle: ["Draconic Evolution is a late-game, super powerful mod, with (arguably) the strongest armor, weapons and bosses available to any mod.", "It offers the biggest Energy Storage available, big and dangerous power generation, super powerful armor and weapons, mob spawning and killing and more.", "Draconic Evolution has its name of being the Power Creep of Modded Minecraft, because it does everything bigger and stronger.", "", "Authored by Discomanco"],
  icon: "minecraft:book"
}
