      x: 5.5,
      y: 7.83,
      tasks: [
        {
          id: "0300000001650000",
          type: "item",
          item: "tconstruct:pick_head"
        }
      ],
      description: ["Besides mining, we'll also be doing a bunch of digging.", "", "Really it's quite inevitable.", "", "While you can dig using your stumps called hands, shovels make the job much easier. Let's take the stencil for the &l'Shovel Head'&r and make it."],
      icon: "tconstruct:pick_head",
